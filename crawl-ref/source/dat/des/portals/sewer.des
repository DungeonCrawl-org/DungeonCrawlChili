## BIG BADDIE (Pargi) ######################################################
# Threat is mostly a single larger creature, often Pargi.

NAME:     pargi_house
TAGS:     no_item_gen no_monster_gen no_pool_fixup sewer_edge no_trap_gen
ORIENT:   north
KMONS:    2 = sewer rat band / bullfrog / wolf
# BCADDO: Restore hounds.
KMONS:    1 = Pargi, crocodile
KITEM:    d = potion of berserk rage / potion of haste w:5
KFEAT:    d = shallow_water
SUBST:    ` = WW.
SUBST:    c : cv
: sewer_setup(_G)
MAP
 ccccccc
cc$***$cc
c%.$*$.%c
c...1...c
c.2.w.2.c
c..wWw..c
c.WwWwW.c
cc.WwW.cc
 cccWccc
   cdc
   c`c
   c`c
   c`c
   c`c
   c`c
   c`c
   c@c
ENDMAP

